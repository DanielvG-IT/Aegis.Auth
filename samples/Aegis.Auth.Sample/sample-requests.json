{
    "signUpEmail": {
        "description": "Sign up with email and password (replace with a unique email each run)",
        "endpoint": "POST /api/auth/sign-up/email",
        "request": {
            "name": "New Sample User",
            "email": "new-user@example.com",
            "password": "Password123!",
            "image": "https://example.com/avatar.png",
            "callback": null
        }
    },
    "signUpDuplicateEmail": {
        "description": "Test duplicate email signup (should fail)",
        "endpoint": "POST /api/auth/sign-up/email",
        "request": {
            "name": "New Sample User",
            "email": "new-user@example.com",
            "password": "Password123!",
            "image": null,
            "callback": null
        }
    },
    "signInEmail": {
        "description": "Sign in with email and password - Remember me enabled",
        "endpoint": "POST /api/auth/sign-in/email",
        "request": {
            "email": "test@example.com",
            "password": "Password123!",
            "rememberMe": true,
            "callback": null
        }
    },
    "signInEmailNoRemember": {
        "description": "Sign in with email and password - Session cookie only",
        "endpoint": "POST /api/auth/sign-in/email",
        "request": {
            "email": "test@example.com",
            "password": "Password123!",
            "rememberMe": false,
            "callback": null
        }
    },
    "signInEmailWithCallback": {
        "description": "Sign in with redirect callback URL",
        "endpoint": "POST /api/auth/sign-in/email",
        "request": {
            "email": "test@example.com",
            "password": "Password123!",
            "rememberMe": true,
            "callback": "https://example.com/dashboard"
        }
    },
    "signInInvalidEmail": {
        "description": "Test invalid email format",
        "endpoint": "POST /api/auth/sign-in/email",
        "request": {
            "email": "not-an-email",
            "password": "Password123!",
            "rememberMe": false,
            "callback": null
        }
    },
    "signInWrongPassword": {
        "description": "Test wrong password",
        "endpoint": "POST /api/auth/sign-in/email",
        "request": {
            "email": "test@example.com",
            "password": "WrongPassword123!",
            "rememberMe": false,
            "callback": null
        }
    },
    "signInNonexistentUser": {
        "description": "Test non-existent user",
        "endpoint": "POST /api/auth/sign-in/email",
        "request": {
            "email": "nonexistent@example.com",
            "password": "Password123!",
            "rememberMe": false,
            "callback": null
        }
    },
    "getMyProjects": {
        "description": "Fetch projects for currently signed-in user",
        "endpoint": "GET /api/projects/my"
    },
    "createProject": {
        "description": "Create a new business project for signed-in user",
        "endpoint": "POST /api/projects",
        "request": {
            "name": "Aegis API Integration",
            "description": "Use Aegis-authenticated endpoints in a real app workflow"
        }
    },
    "getProjectTasks": {
        "description": "List tasks in a project owned by the signed-in user",
        "endpoint": "GET /api/projects/{projectId}/tasks"
    },
    "addTask": {
        "description": "Add a task to a project owned by the signed-in user",
        "endpoint": "POST /api/projects/{projectId}/tasks",
        "request": {
            "title": "Hook dashboard to authenticated project API"
        }
    }
}
