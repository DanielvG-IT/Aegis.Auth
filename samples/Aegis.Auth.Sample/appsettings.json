{
    "ConnectionStrings": {
        "DefaultConnection": "Data Source=aegis-auth-sample.db"
    },
    "AegisHttp": {
        "BasePath": "/api/auth",
        "TagName": "Aegis Auth",
        "MapSignOut": true,
        "MapEmailSignIn": true,
        "MapEmailSignUp": true,
        "RespectConfiguration": true
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Aegis.Auth": "Debug"
        }
    },
    "AllowedHosts": "*"
}
